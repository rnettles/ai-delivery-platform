{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "execution_contract.schema.json",
  "title": "ExecutionContract",
  "description": "Per-task binding execution contract emitted by the Sprint Planner. Layer 0 (per-task data); Layer 1 invariants and Layer 3 role mechanics live separately (ADR-031).",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "contract_version",
    "task_id",
    "sprint_id",
    "scope",
    "dependencies",
    "commands",
    "determinism",
    "success_criteria",
    "evidence_required",
    "verification_inputs"
  ],
  "properties": {
    "contract_version": {
      "type": "integer",
      "const": 1
    },
    "task_id": {
      "type": "string"
    },
    "sprint_id": {
      "type": "string"
    },
    "scope": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "allowed_paths",
        "allowed_paths_extra",
        "forbidden_actions"
      ],
      "properties": {
        "allowed_paths": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "allowed_paths_extra": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "forbidden_actions": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": [
              "add_new_routes",
              "modify_api_layer",
              "introduce_new_dependencies_outside_scope",
              "rename_files",
              "move_directories",
              "refactor_unrelated_code"
            ]
          }
        }
      }
    },
    "dependencies": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "allowed",
        "install_command"
      ],
      "properties": {
        "allowed": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "install_command": {
          "type": "string"
        }
      }
    },
    "commands": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "lint",
        "typecheck",
        "test"
      ],
      "properties": {
        "lint": {
          "type": "string"
        },
        "typecheck": {
          "type": "string"
        },
        "test": {
          "type": "string"
        },
        "working_directory": {
          "type": "string",
          "description": "Optional sub-directory relative to repo root from which all commands run. Used when package.json lives in a subdirectory."
        }
      }
    },
    "determinism": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "idempotent_runtime",
        "no_randomness",
        "no_external_calls"
      ],
      "properties": {
        "idempotent_runtime": {
          "anyOf": [
            {
              "type": "boolean"
            },
            {
              "type": "string",
              "const": "n/a"
            }
          ]
        },
        "no_randomness": {
          "type": "boolean"
        },
        "no_external_calls": {
          "type": "boolean"
        }
      }
    },
    "success_criteria": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "all_tests_pass",
        "lint_pass",
        "typecheck_pass",
        "no_regressions"
      ],
      "properties": {
        "all_tests_pass": {
          "type": "boolean"
        },
        "lint_pass": {
          "type": "boolean"
        },
        "typecheck_pass": {
          "type": "boolean"
        },
        "no_regressions": {
          "type": "boolean"
        }
      }
    },
    "evidence_required": {
      "type": "boolean"
    },
    "verification_inputs": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  }
}
