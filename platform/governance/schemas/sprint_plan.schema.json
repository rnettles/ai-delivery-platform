{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "required": [
    "sprint_id",
    "phase_id",
    "tasks"
  ],
  "properties": {
    "sprint_id": {
      "type": "string"
    },
    "phase_id": {
      "type": "string"
    },
    "name": {
      "type": "string"
    },
    "goals": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "tasks": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "status": {
      "type": "string",
      "enum": ["staged", "active", "complete"]
    }
  }
}
