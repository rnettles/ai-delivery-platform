{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "sprint_plan_rich.schema.json",
  "title": "RichSprintLlmResponse",
  "description": "Rich Sprint Plan emitted by the Sprint Planner LLM call. Carries full per-task specifications including execution_contract. Schema-strict; consumed by the deterministic markdown renderer and Sprint Controller staging.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "plan_version",
    "sprint_plan",
    "task_specifications",
    "first_task_id"
  ],
  "$defs": {
    "ExecutionContract": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "contract_version",
        "task_id",
        "sprint_id",
        "scope",
        "dependencies",
        "commands",
        "determinism",
        "success_criteria",
        "evidence_required",
        "verification_inputs"
      ],
      "properties": {
        "contract_version": {
          "type": "integer",
          "const": 1
        },
        "task_id": {
          "type": "string"
        },
        "sprint_id": {
          "type": "string"
        },
        "scope": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "allowed_paths",
            "allowed_paths_extra",
            "forbidden_actions"
          ],
          "properties": {
            "allowed_paths": {
              "type": "array",
              "items": {
                "type": "string"
              }
            },
            "allowed_paths_extra": {
              "type": "array",
              "items": {
                "type": "string"
              }
            },
            "forbidden_actions": {
              "type": "array",
              "items": {
                "type": "string",
                "enum": [
                  "add_new_routes",
                  "modify_api_layer",
                  "introduce_new_dependencies_outside_scope",
                  "rename_files",
                  "move_directories",
                  "refactor_unrelated_code"
                ]
              }
            }
          }
        },
        "dependencies": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "allowed",
            "install_command"
          ],
          "properties": {
            "allowed": {
              "type": "array",
              "items": {
                "type": "string"
              }
            },
            "install_command": {
              "type": "string"
            }
          }
        },
        "commands": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "lint",
            "typecheck",
            "test"
          ],
          "properties": {
            "lint": {
              "type": "string"
            },
            "typecheck": {
              "type": "string"
            },
            "test": {
              "type": "string"
            }
          }
        },
        "determinism": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "idempotent_runtime",
            "no_randomness",
            "no_external_calls"
          ],
          "properties": {
            "idempotent_runtime": {
              "type": "string"
            },
            "no_randomness": {
              "type": "boolean"
            },
            "no_external_calls": {
              "type": "boolean"
            }
          }
        },
        "success_criteria": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "all_tests_pass",
            "lint_pass",
            "typecheck_pass",
            "no_regressions"
          ],
          "properties": {
            "all_tests_pass": {
              "type": "boolean"
            },
            "lint_pass": {
              "type": "boolean"
            },
            "typecheck_pass": {
              "type": "boolean"
            },
            "no_regressions": {
              "type": "boolean"
            }
          }
        },
        "evidence_required": {
          "type": "boolean"
        },
        "verification_inputs": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    }
  },
  "properties": {
    "plan_version": {
      "type": "integer",
      "const": 1
    },
    "first_task_id": {
      "type": "string"
    },
    "sprint_plan": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "sprint_id",
        "phase_id",
        "name",
        "status",
        "execution_mode",
        "overview",
        "design_decisions",
        "goals",
        "tasks",
        "data_contracts",
        "invariants",
        "dependency_graph",
        "test_matrix",
        "validation_gates",
        "definition_of_done",
        "fast_track_lane",
        "fast_track_rationale",
        "fast_track_intake_id"
      ],
      "properties": {
        "sprint_id": {
          "type": "string"
        },
        "phase_id": {
          "type": "string"
        },
        "name": {
          "type": "string"
        },
        "status": {
          "type": "string",
          "const": "staged"
        },
        "execution_mode": {
          "type": "string",
          "enum": [
            "normal",
            "fast-track"
          ]
        },
        "overview": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "purpose",
            "scope"
          ],
          "properties": {
            "purpose": {
              "type": "string"
            },
            "scope": {
              "type": "string"
            }
          }
        },
        "design_decisions": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "decision",
              "choice",
              "rationale"
            ],
            "properties": {
              "decision": {
                "type": "string"
              },
              "choice": {
                "type": "string"
              },
              "rationale": {
                "type": "string"
              }
            }
          }
        },
        "goals": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "tasks": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "data_contracts": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "name",
              "kind",
              "description",
              "json_schema"
            ],
            "properties": {
              "name": {
                "type": "string"
              },
              "kind": {
                "type": "string",
                "enum": [
                  "request",
                  "response",
                  "entity",
                  "event",
                  "db_row",
                  "config"
                ]
              },
              "description": {
                "type": "string"
              },
              "json_schema": {
                "type": "string"
              }
            }
          }
        },
        "invariants": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "id",
              "statement",
              "testable_via"
            ],
            "properties": {
              "id": {
                "type": "string"
              },
              "statement": {
                "type": "string"
              },
              "testable_via": {
                "type": "string"
              }
            }
          }
        },
        "dependency_graph": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "task_id",
              "depends_on"
            ],
            "properties": {
              "task_id": {
                "type": "string"
              },
              "depends_on": {
                "type": "array",
                "items": {
                  "type": "string"
                }
              }
            }
          }
        },
        "test_matrix": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "task_id",
              "normal",
              "edge",
              "failure",
              "idempotency"
            ],
            "properties": {
              "task_id": {
                "type": "string"
              },
              "normal": {
                "type": "array",
                "items": {
                  "type": "string"
                }
              },
              "edge": {
                "type": "array",
                "items": {
                  "type": "string"
                }
              },
              "failure": {
                "type": "array",
                "items": {
                  "type": "string"
                }
              },
              "idempotency": {
                "type": "array",
                "items": {
                  "type": "string"
                }
              }
            }
          }
        },
        "validation_gates": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": [
              "lint",
              "typecheck",
              "unit",
              "integration",
              "contract"
            ]
          }
        },
        "definition_of_done": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "fast_track_lane": {
          "type": "string"
        },
        "fast_track_rationale": {
          "type": "string"
        },
        "fast_track_intake_id": {
          "type": "string"
        }
      }
    },
    "task_specifications": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "task_id",
          "title",
          "description",
          "subsystem",
          "fr_ids_in_scope",
          "inputs",
          "outputs",
          "implementation_notes",
          "acceptance_criteria",
          "estimated_effort",
          "files_likely_affected",
          "depends_on",
          "test_refs",
          "invariant_refs",
          "contract_refs",
          "task_flags",
          "execution_contract"
        ],
        "properties": {
          "task_id": {
            "type": "string"
          },
          "title": {
            "type": "string"
          },
          "description": {
            "type": "string"
          },
          "subsystem": {
            "type": "string"
          },
          "fr_ids_in_scope": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "inputs": {
            "type": "array",
            "items": {
              "type": "object",
              "additionalProperties": false,
              "required": [
                "name",
                "type",
                "source",
                "sink"
              ],
              "properties": {
                "name": {
                  "type": "string"
                },
                "type": {
                  "type": "string"
                },
                "source": {
                  "type": "string"
                },
                "sink": {
                  "type": "string"
                }
              }
            }
          },
          "outputs": {
            "type": "array",
            "items": {
              "type": "object",
              "additionalProperties": false,
              "required": [
                "name",
                "type",
                "source",
                "sink"
              ],
              "properties": {
                "name": {
                  "type": "string"
                },
                "type": {
                  "type": "string"
                },
                "source": {
                  "type": "string"
                },
                "sink": {
                  "type": "string"
                }
              }
            }
          },
          "implementation_notes": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "acceptance_criteria": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "estimated_effort": {
            "type": "string",
            "enum": [
              "S",
              "M",
              "L"
            ]
          },
          "files_likely_affected": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "depends_on": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "test_refs": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "invariant_refs": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "contract_refs": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "task_flags": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "fr_ids_in_scope",
              "architecture_contract_change",
              "ui_evidence_required",
              "incident_tier",
              "schema_change",
              "migration_change",
              "cross_subsystem_change"
            ],
            "properties": {
              "fr_ids_in_scope": {
                "type": "array",
                "items": {
                  "type": "string"
                }
              },
              "architecture_contract_change": {
                "type": "boolean"
              },
              "ui_evidence_required": {
                "type": "boolean"
              },
              "incident_tier": {
                "type": "string",
                "enum": [
                  "none",
                  "p0",
                  "p1",
                  "p2",
                  "p3"
                ]
              },
              "schema_change": {
                "type": "boolean"
              },
              "migration_change": {
                "type": "boolean"
              },
              "cross_subsystem_change": {
                "type": "boolean"
              }
            }
          },
          "execution_contract": {
            "$ref": "#/$defs/ExecutionContract"
          }
        }
      }
    }
  }
}
