PORT=3000
NODE_ENV=development
LOG_LEVEL=info

# Postgres connection string
DATABASE_URL=postgresql://user:password@localhost:5432/ai_orchestrator_dev_state

# Azure OpenAI
AZURE_OPENAI_ENDPOINT=https://<resource>.openai.azure.com/
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_DEPLOYMENT=gpt-4.1

# n8n callback URL (for pipeline step notifications)
N8N_CALLBACK_URL=http://localhost:5678/webhook/...

# Optional default channel for pipeline-related notifications
PIPELINE_SLACK_CHANNEL=

# CLI command notifications
# When set, backend accepts CLI notifications and routes them to this channel.
CLI_NOTIFICATION_CHANNEL=
# false = only state-changing CLI commands notify
# true  = all CLI commands notify
CLI_VERBOSE_MODE=false

# Local artifact storage path
ARTIFACT_BASE_PATH=./artifacts

# Governance content path (ADR-025)
# In production: bundled at /app/governance/ inside the container (default: ./governance)
# For local dev: set to ../governance (relative to platform/backend-api/)
GOVERNANCE_PATH=../governance

# Git sync — Execution Service owns all git operations (ADR-011)
# GIT_REPO_URL: HTTPS URL of the repo to clone (e.g. https://github.com/org/repo.git)
# GIT_PAT: Personal Access Token injected into clone URL (stored as Azure secret in prod)
# GIT_CLONE_PATH: Local path for the clone; on Azure Files mount this is /mnt/repo
GIT_REPO_URL=https://github.com/rnettles/ai-delivery-platform.git
GIT_PAT=
GIT_CLONE_PATH=./repo
