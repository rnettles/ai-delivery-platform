{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "additionalProperties": false,
  "required": ["script", "input"],
  "properties": {
    "execution_id": {
      "type": "string",
      "minLength": 1
    },
    "script": {
      "type": "string",
      "minLength": 1
    },
    "input": {
      "type": "object"
    },
    "metadata": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "source": {
          "type": "string"
        },
        "correlation_id": {
          "type": "string"
        }
      }
    }
  }
}
